# AUTH0_AUDIENCE=
# AUTH0_CLIENT_ID=
# AUTH0_CLIENT_SECRET=
# AUTH0_ISSUER_BASE_URL=
# AUTH0_SECRET=

# Legal/branding
LEGAL_OWNER="Bespoke Champions League Ltd"
LEGAL_CONTACT="contact@bespea.com"

# OpenAI/Anthropic/Gemini (optional, not used by default)
# OPENAI_API_KEY=
# OPENAI_MODEL=
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=
# GEMINI_API_KEY=
# GEMINI_MODEL=

# OAuth (Google)
GOOGLE_CLIENT_ID=change-me
GOOGLE_CLIENT_SECRET=change-me
GOOGLE_CLIENT_SECRET=change-me
GOOGLE_CALLBACK_URL=http://localhost:3101/api/auth/google/callback

# OAuth (GitHub)
GITHUB_CLIENT_ID=change-me
GITHUB_CLIENT_SECRET=change-me
