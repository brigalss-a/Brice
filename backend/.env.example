PORT=3101
NODE_ENV=development
STORAGE_MODE=auto
DATABASE_URL=postgres://brice:brice@localhost:5432/brice
JWT_SECRET=change-me
JWT_REFRESH_SECRET=change-me-too
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d
SESSION_COOKIE_NAME=brice_session
BRICE_SERVER_API_KEYS=local-dev-key-1
OTEL_SERVICE_NAME=brice-sentinel-backend
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318
DASHBOARD_ORIGIN=http://localhost:5173

# Redis/BullMQ (planned, not yet implemented)
REDIS_URL=redis://localhost:6380

# Auth0 SSO (planned, not yet implemented)
# Auth0 SSO (planned, not yet implemented)
